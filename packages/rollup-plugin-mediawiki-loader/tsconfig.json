{
    "extends": "../../tsconfig.multi.declaration.json",
    "compilerOptions": {
        "declarationDir": "types",
        "paths": {
            "#monorepo-root/*": [
                "../../*"
            ]
        },
        "rootDir": "../.."
    },
    "include": [
        "**/*.ts",
        "../../*"
