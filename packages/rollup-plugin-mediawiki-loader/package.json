{
  "name": "rollup-plugin-mediawiki-loader",
  "version": "0.1.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "--main": "main.js",
  "--types": "main.d.ts",
  "exports": {
    ".": {
      "types": "./main.d.ts",
      "default": "./main.js"
    },
    "./*": {
      "types": "./types/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run bundle",
    "bundle": "rollup --config ../../rollup.multi.config.js",
    "generate-declaration": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "--files": [
    "*.d.ts",
    "*.map",
    "dist/*"
  ],
  "peerDependencies": {
    "rollup": "^4.34.9"
  }
}